{
  // ./typescript/tsconfig.json
  "compilerOptions": {
    /* Projects */
    "composite": true,
    "disableSourceOfProjectReferenceRedirect": false,
    "disableSolutionSearching": false,
    "disableReferencedProjectLoad": false,
    /* Compilation Options */
    "noErrorTruncation": true,
    "useDefineForClassFields": true,
    "assumeChangesOnlyAffectDirectDependencies": false,
    /* Completeness */
    "importHelpers": true,
    "skipDefaultLibCheck": false,
    "skipLibCheck": true,
    "noResolve": false,
    "noLib": false,
    "moduleDetection": "force",
    /* Verbosity */
    "diagnostics": true,
    "extendedDiagnostics": true,
    "listEmittedFiles": false,
    "listFiles": false,
    "traceResolution": false,
    /* Emit Options */
    "target": "ESNext",
    "module": "CommonJS",
    // "moduleResolution": "node",
    "rootDir": "./src",
    "declarationDir": "./lib/typings",
    "outDir": "./lib/src",
    "tsBuildInfoFile": "./lib/ts-out-info.lib",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": false,
    /* JavaScript Support */
    "allowJs": true,
    "checkJs": false,
    /* Bundled library declaration files that describe the target runtime environment. */
    "lib": ["dom", "esnext"],
    /* Package names to be included without being referenced in a source file. */
    "types": ["node", "heft-jest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src"],
  "exclude": ["lib", "**/jest.*.js"],
  /* Add this block to restore seamless runtime path mapping */
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
